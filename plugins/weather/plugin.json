{
    "id":"get_weather_forecast",
    "name":"Get weather forecast for next 18hrs",
    "enabled":true,
    "invocation_with":"source .venv/bin/activate; python3",
    "invocation_file":"weather.py",
    "invocation_type": "sync",
    "invocation_timeout_s": 45,
    "options":["Cyprus, Limassol","Cyprus, Paphos","Cyprus, Larnaca", "Cyprus, Nicosia"],
    "adhoc":true,
    "cron":true,
    "cron_time":"30 7 * * *",
    "min_allowed_role": "guest"
}